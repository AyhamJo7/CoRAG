# LLM Provider Configuration (only OpenAI-compatible providers are supported)
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=https://api.openai.com/v1

# Default LLM Settings
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_TEMPERATURE=0.2
DEFAULT_MAX_TOKENS=2048

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/msmarco-distilbert-base-v4
EMBEDDING_DEVICE=cpu

# Index Configuration
FAISS_INDEX_TYPE=Flat
FAISS_NLIST=100

# Retrieval Settings
DEFAULT_TOP_K=8
DEFAULT_MAX_STEPS=6
DEFAULT_CHUNK_SIZE=512
DEFAULT_CHUNK_OVERLAP=64

# Application Settings
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Data Paths
DATA_DIR=./data
INDEX_DIR=./data/index
CORPUS_PATH=./data/corpus.jsonl

# ─── CoRAG Cloud (SaaS stack; see docker-compose.yml) ──────────────────────
# development | test | production — production refuses insecure defaults
ENVIRONMENT=development

# Postgres superuser password (migrations/provisioning) and app-role password
POSTGRES_PASSWORD=
CORAG_APP_DB_PASSWORD=

# Shared secret between the Next.js BFF and the FastAPI backend (>= 32 chars)
INTERNAL_SERVICE_TOKEN=

# Salt for hashing developer API keys (>= 32 chars, unique per deployment)
API_KEY_SALT=

# Auth.js session encryption secret (generate: openssl rand -base64 33)
AUTH_SECRET=

# Stripe (TEST mode until the company-registration gate lifts)
# One iQuantum Stripe account; prices created per plan in the dashboard.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...

# Set outside compose only; inside compose these are derived automatically
# DATABASE_URL=postgresql://corag_app:...@localhost:5432/corag
# DATABASE_ADMIN_URL=postgresql://postgres:...@localhost:5432/corag
